def get_realtime_sentiment(ticker):
    print(f"--- Fetching Live Sentiment for {ticker} ---")
    
    # 1. Get Live News
    url = f'https://newsapi.org/v2/everything?q={ticker}&language=en&sortBy=publishedAt&pageSize=10&apiKey={NEWS_API_KEY}'
    response = requests.get(url).json()
    articles = response.get('articles', [])
    
    if not articles:
        return "No recent news found for this ticker."

    # 2. Prepare Data for Gemini
    news_feed = ""
    for i, a in enumerate(articles):
        news_feed += f"{i+1}. {a['title']} - {a['description']}\n\n"

    # 3. The "Sentiment Logic" Prompt
    prompt = f"""
    You are a Quantitative Sentiment Analyst for the S&P 500. 
    Analyze these 10 news headlines for {ticker}:
    
    {news_feed}
    
    TASK:
    1. Assign a 'Fear & Greed' score from -100 (Extreme Fear) to +100 (Extreme Greed).
    2. Categorize the sentiment into: 'Bullish', 'Neutral', or 'Bearish'.
    3. EXPLAIN the 'Why': What is the single biggest narrative driving this score?
    4. IMPACT ON MULTIPLES: Does this sentiment suggest the P/E ratio should expand or contract?
    5. Include sources used
    6. Create an overall sentiment score out of 10 with 10 being the best an 0 the worst
    
    Provide the output in a clean, professional bulletin format.
    """

    # 4. Generate Analysis
    analysis = client.models.generate_content(
        model="gemini-3-flash-preview", 
        contents=prompt
    )
    
    return analysis.text

